NODE_ENV=production

PORT=3000
HOST=0.0.0.0

LOG_LEVEL=debug

CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

API_PREFIX=/api
API_VERSION=v1

API_KEY_ENABLED=false
API_KEY=your-development-secret-key-change-in-production

# EXTERNAL_API_URL=http://localhost:8000
# EXTERNAL_API_KEY=development-key

ENABLE_SWAGGER=true
ENABLE_HEALTH_CHECK=true

APP_NAME=assessment-db-domain-service
APP_DESCRIPTION=Database domain backend service application

# Database Configuration (PostgreSQL)
DB_HOST=your-db-host
DB_PORT=5432
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
DB_DATABASE=assessment_db
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=true
